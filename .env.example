# Configuración (plantilla) — copia este archivo a `.env` y completa los valores.
# No incluyas secretos en el repositorio.

# URL pública de la app
APP_URL=

# App settings (server)
HOST=
PORT=
NODE_ENV=

# External API endpoint (Rick & Morty)
CHARACTER_ENDPOINT=

# Base pública que el front consumirá; se inyecta en runtime desde /config.js
API_BASE=