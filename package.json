{
    "name": "js-backend",
    "version": "0.0.0",
    "private": true,
    "main": "index.js",
    "scripts": {
        "dev": "nodemon src/index.js",
        "coverage": "vitest run --coverage",
        "start": "node src/index.js",
        "lint": "eslint .",
        "prepare": "husky || true",
        "e2e:run": "NODE_ENV=e2e vitest --exclude '**/*.test.js' --watch=false",
        "e2e:coverage": "NODE_ENV=e2e vitest run --coverage --exclude '**/*.test.js' --watch=false",
        "e2e:wait-db": "bash scripts/wait-for-db.sh db-e2e",
        "e2e:restart-smb": "bash scripts/restart-smb-e2e.sh",
        "e2e:wait-smb": "bash scripts/wait-for-smb.sh smb-dgpe-e2e",
        "e2e:init-data-volumes": "bash scripts/init-data-volumes.sh",
        "e2e:fix-sftp-permissions": "bash scripts/fix-sftp-permissions.sh",
        "e2e:create-containers": "docker compose -f .devcontainer/docker-compose.yml --profile e2e up -d",
        "e2e:remove-containers": "docker compose -f .devcontainer/docker-compose.yml --profile e2e down --volumes",
        "e2e": "npm run e2e:create-containers && npm run e2e:init-data-volumes && npm run e2e:wait-db && npm run e2e:wait-smb && npm run e2e:fix-sftp-permissions && npm run e2e:run; npm run e2e:remove-containers"
    },
    "devDependencies": {
        "@commitlint/cli": "^19.3.0",
        "@commitlint/config-conventional": "^19.2.2",
        "@vitest/coverage-v8": "^1.4.0",
        "async_hooks": "^1.0.0",
        "eslint": "^8.57.0",
        "eslint-config-airbnb-base": "^15.0.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-import": "^2.29.1",
        "eslint-plugin-prettier": "^5.1.3",
        "husky": "^9.0.11",
        "jest": "^29.7.0",
        "lint-staged": "^15.2.2",
        "msw": "^2.7.3",
        "nodemon": "^3.0.2",
        "prettier": "3.2.5",
        "supertest": "^7.0.0",
        "vitest": "^1.4.0"
    },
    "dependencies": {
        "@faker-js/faker": "^8.4.1",
        "@hapi/boom": "^10.0.1",
        "axios": "^1.6.6",
        "dotenv": "^16.3.2",
        "exceljs": "^4.4.0",
        "express": "^4.19.2",
        "express-openapi-validator": "^5.4.3",
        "js-yaml": "^4.1.0"
    }
}
